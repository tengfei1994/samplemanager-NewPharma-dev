    <Reference Include="Thermo.Framework.Server"><HintPath>Thermo.Framework.Server.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="Thermo.Framework.Utilities"><HintPath>Thermo.Framework.Utilities.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="Thermo.SampleManager.Common"><HintPath>Thermo.SampleManager.Common.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="Thermo.SampleManager.Core"><HintPath>Thermo.SampleManager.Core.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="Thermo.SampleManager.Internal.ObjectModel"><HintPath>Thermo.SampleManager.Internal.ObjectModel.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="Thermo.SampleManager.Library"><HintPath>Thermo.SampleManager.Library.dll</HintPath><Private>False</Private></Reference>
    <Reference Include="Thermo.SampleManager.ObjectModel"><HintPath>Thermo.SampleManager.ObjectModel.dll</HintPath><Private>False</Private></Reference>
